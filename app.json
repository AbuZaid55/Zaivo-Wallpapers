{
  "expo": {
    "name": "Zaivo Wallpapers",
    "slug": "zaivo-wallpapers",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icons/zaivo_icon.png",
    "scheme": "wallpaperapp",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icons/zaivo_icon.png",
        "backgroundColor": "#0A1633"
      },
      "package": "com.zaivo.wallpapers"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icons/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/icons/zaivo_icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
